NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# The same database the Express server uses — client/prisma/schema.prisma reads this too.
DATABASE_URL="postgresql://aiuser:aipassword@localhost:5432/ai_messaging"

# NextAuth. There is no fallback for the secret — auth fails without it.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=""

# Used by the vibe-search route.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional — auth verification and password-reset emails only.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
