# Credentials match docker-compose.yml (aiuser / aipassword / ai_messaging).
DATABASE_URL="postgresql://aiuser:aipassword@localhost:5432/ai_messaging"
REDIS_URL="redis://localhost:6379"
ANTHROPIC_API_KEY="sk-ant-..."
PORT=3001

# Origin allowed through CORS. Optional locally — defaults to http://localhost:3000.
# Set this in production to the deployed client URL.
CLIENT_URL="http://localhost:3000"

# REQUIRED. Must be byte-identical to the client's NEXTAUTH_SECRET
# (client/.env.local locally; the Vercel environment variable in production).
#
# NextAuth issues the session token; this server derives the same encryption key
# from this secret to open it and learn who is calling. It is the only thing
# standing between a request and acting as any user it names, so the server
# refuses to boot without it rather than falling back to trusting the caller.
#
# If the two sides ever hold different values, no token verifies and every
# request 401s — the site reads as permanently signed out.
NEXTAUTH_SECRET=""
