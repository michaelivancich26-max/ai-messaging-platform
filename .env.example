# Credentials match docker-compose.yml (aiuser / aipassword / ai_messaging).
DATABASE_URL="postgresql://aiuser:aipassword@localhost:5432/ai_messaging"
REDIS_URL="redis://localhost:6379"
ANTHROPIC_API_KEY="sk-ant-..."
PORT=3001

# Origin allowed through CORS. Optional locally — defaults to http://localhost:3000.
# Set this in production to the deployed client URL.
CLIENT_URL="http://localhost:3000"
