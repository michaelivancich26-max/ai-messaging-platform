datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SenderType {
  HUMAN
  AI
}

enum ClaimStatus {
  PENDING
  SUPPORTED
  REFUTED
  CONTESTED
}

enum DebatePosition {
  FOR
  AGAINST
  NEUTRAL
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  password     String
  isAdmin      Boolean   @default(false)
  bio          String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  messages     Message[]
  roomsCreated Room[]
  roomMembers  RoomMember[]
}

model RoomMember {
  id        String   @id @default(cuid())
  userId    String
  roomId    String
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model Room {
  id             String    @id @default(cuid())
  name           String    @unique
  description    String?
  createdAt      DateTime  @default(now())
  creatorId      String?
  creator        User?     @relation(fields: [creatorId], references: [id])
  isPrivate      Boolean   @default(false)
  password       String?
  maxMembers     Int?
  isDM           Boolean   @default(false)
  participant1Id String?
  participant2Id String?
  aiPersona      String?
  proposition    String?
  messages       Message[]
  sections       Section[]
  channels       Channel[]
  graphNodes     GraphNode[]
  graphEdges     GraphEdge[]
  members        RoomMember[]
  polls          Poll[]
  claims         Claim[]
}

model Poll {
  id        String     @id @default(cuid())
  roomId    String
  channelId String?
  question  String
  options   String[]
  createdBy String
  closedAt  DateTime?
  createdAt DateTime   @default(now())
  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  votes     PollVote[]
}

model PollVote {
  id      String @id @default(cuid())
  pollId  String
  userId  String
  option  String
  poll    Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model Section {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  channels  Channel[]
  createdAt DateTime  @default(now())
}

model Channel {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sectionId String?
  section   Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  isSidebar            Boolean   @default(false)
  isSubDebate          Boolean   @default(false)
  proposition          String?
  parentMessageId      String?
  parentMessagePreview String?
  parentChannelId      String?
  messages             Message[]
  createdAt            DateTime  @default(now())
}

model GraphNode {
  id           String               @id @default(cuid())
  label        String
  type         String               // person | place | topic | concept
  roomId       String
  room         Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fromEdges    GraphEdge[]          @relation("FromNode")
  toEdges      GraphEdge[]          @relation("ToNode")
  corrections  GraphNodeMessage[]
  createdAt    DateTime             @default(now())

  @@unique([label, roomId])
}

model GraphNodeMessage {
  id        String    @id @default(cuid())
  nodeId    String
  messageId String
  node      GraphNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([nodeId, messageId])
}

model GraphEdge {
  id         String    @id @default(cuid())
  label      String
  roomId     String
  fromNodeId String
  toNodeId   String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fromNode   GraphNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     GraphNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
}

model Message {
  id         String     @id @default(cuid())
  content    String
  senderType SenderType
  createdAt  DateTime   @default(now())
  userId     String?
  roomId     String
  channelId  String?
  user         User?              @relation(fields: [userId], references: [id])
  room         Room               @relation(fields: [roomId], references: [id])
  channel      Channel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  graphNodes   GraphNodeMessage[]
  claims       Claim[]
}

model Claim {
  id          String           @id @default(cuid())
  messageId   String
  roomId      String
  channelId   String?
  claimantId  String
  text        String
  status      ClaimStatus      @default(PENDING)
  verdict     String?
  relevance   Float            @default(1.0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  message     Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)
  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  challenges  ClaimChallenge[]
}

model ClaimChallenge {
  id           String   @id @default(cuid())
  claimId      String
  challengerId String
  createdAt    DateTime @default(now())
  claim        Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
}

model UserPosition {
  id        String         @id @default(cuid())
  userId    String
  roomId    String
  position  DebatePosition
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())

  @@unique([userId, roomId])
}
